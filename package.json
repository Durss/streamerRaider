{
	"name": "streamer_raider",
	"version": "1.0.0",
	"private": true,
	"scripts": {
		"dev": "concurrently --kill-others \"npm run front/watch\" \"npm run server/watch\"",
		"build": "npm run front/build && npm run server/build",
		"front/serve": "vite",
		"front/watch": "vite",
		"front/build": "vue-tsc --noEmit && vite build",
		"server/watch": "tsc -w -p ./tsconfig_server.json",
		"server/build": "tsc -p ./tsconfig_server.json",
		"server/start": "pm2 start bootstrap-pm2.json"
	},
	"dependencies": {
		"concurrently": "^6.5.1",
		"connect-history-api-fallback": "^1.6.0",
		"crypto-js": "^4.2.0",
		"discord.js": "^13.17.1",
		"express": "^4.22.2",
		"express-rate-limit": "^5.5.1",
		"express-slow-down": "^1.6.0",
		"multiparty": "^4.3.0",
		"node-fetch": "^2.7.0",
		"pinia": "^2.3.1",
		"tmi.js": "^1.8.5",
		"vue": "^3.5.13",
		"vue-router": "^4.5.0"
	},
	"devDependencies": {
		"@types/crypto-js": "^4.2.2",
		"@types/express": "^4.17.25",
		"@types/multiparty": "0.0.33",
		"@types/node": "^20.14.0",
		"@types/node-fetch": "^2.6.13",
		"@types/tmi.js": "^1.8.6",
		"@types/uuid": "^8.3.4",
		"@vitejs/plugin-vue": "^6.0.7",
		"gsap": "^3.15.0",
		"less": "^4.2.1",
		"typescript": "^5.6.3",
		"vite": "^8.0.16",
		"vue-tsc": "^3.3.5"
	},
	"browserslist": [
		"> 1%",
		"last 2 versions"
	]
}